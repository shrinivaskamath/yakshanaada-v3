# Optional: Firebase web config for visit analytics (GA4).
# Copy this file to `.env` and fill in the values from the Firebase console:
#   Project settings -> Your apps -> Web app -> SDK setup and configuration.
# These are NOT secrets (they ship in every Firebase web client).
# If you prefer, you can instead hardcode them in src/firebase.ts.
#
# Only appId and measurementId are required to start counting visits; the rest
# already default to the yakshanaadav3 project.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=yakshanaadav3.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=yakshanaadav3
VITE_FIREBASE_STORAGE_BUCKET=yakshanaadav3.appspot.com
VITE_FIREBASE_SENDER_ID=720971405897
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
